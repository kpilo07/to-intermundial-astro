---
/**
 * Footer — fiel al diseño de page_footer.html.twig
 *
 * Secciones:
 *  1. Stats         — gradiente surface-blue2 → content-high
 *  2. Nav columns   — bg-content-high, logo + 4 columnas con acordeón mobile
 *  3. App / Pagos   — badges App Store / Google Play + iconos de pago
 *  4. Social / País — redes sociales + logo Atlantigo + selector de país
 *  5. Legal         — copyright izquierda + links legales derecha
 */
import type { FooterData, FooterColumn, FooterSubItem } from '../lib/types';

interface Props {
  footer: FooterData;
}

const { footer } = Astro.props;

const stats = [
  { value: '+5.7M',  label: 'clientes activos' },
  { value: '+64K',   label: 'opiniones de clientes' },
  { value: '+224K',  label: 'seguros emitidos en 2024' },
  { value: '+6K',    label: 'destinos cubiertos' },
];

const socialLinks = [
  {
    href: 'https://www.instagram.com/intermundial_seguros/',
    label: 'Instagram',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    href: 'https://www.tiktok.com/@intermundial_seguros',
    label: 'TikTok',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.93a8.16 8.16 0 004.77 1.52V7.01a4.85 4.85 0 01-1-.32z"/></svg>`,
  },
  {
    href: 'https://www.facebook.com/intermundial/',
    label: 'Facebook',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>`,
  },
  {
    href: 'https://www.youtube.com/user/Intermundial',
    label: 'YouTube',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>`,
  },
  {
    href: 'https://www.linkedin.com/company/intermundial/',
    label: 'LinkedIn',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
];

const countries = [
  { label: 'México',    url: 'https://www.intermundial.com.mx/' },
  { label: 'Colombia',  url: 'https://www.intermundial.com.co/' },
  { label: 'España',    url: 'https://www.intermundial.es/',     selected: true },
  { label: 'Italia',    url: 'https://www.intermundial.it/' },
  { label: 'Portugal',  url: 'http://www.intermundial.pt/' },
];

const paymentMethods = [
  { alt: 'Visa',             slug: 'visa' },
  { alt: 'American Express', slug: 'amex' },
  { alt: 'Mastercard',       slug: 'mastercard' },
  { alt: 'PayPal',           slug: 'paypal' },
  { alt: 'Bizum',            slug: 'bizum' },
];
---

<footer class="rounded-t-16 overflow-hidden bg-gradient-to-b from-surface-blue2 from-50% to-content-high to-50% opacity-100 transition-all duration-300 mt-0">

  <!-- ── 1. Stats ──────────────────────────────────────────────────── -->
  <div class="py-40 px-32 pb-56 max-s:py-32 max-s:px-24">
    <div class="max-w-[1600px] mx-auto">
      <div class="flex justify-center max-s:flex-col">
        {stats.map((stat) => (
          <div class="flex flex-col items-center mr-[104px] last:mr-0 max-m:mr-48 max-s:mr-0 max-s:mb-24 max-s:last:mb-0 max-xs:w-full text-center">
            <div class="mb-8">
              <span class="font-helvetica-now-medium font-weight-medium text-semantic-primary
                           text-[3.5rem] leading-[1] max-m:text-[2rem] max-xs:text-[1.75rem]">
                {stat.value}
              </span>
            </div>
            <span class="text-14 leading-20 text-content-mid font-helvetica-now-regular">
              {stat.label}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── 2. Nav columns ────────────────────────────────────────────── -->
  <nav
    aria-label="Navegación footer"
    class="bg-content-high text-white pt-40 px-32 pb-[80px] flex justify-center rounded-t-16 max-s:px-24 max-s:pb-40"
  >
    <div class="flex justify-between w-full max-w-[1600px] max-m:block">

      <!-- Logo -->
      <div class="w-auto mb-40 max-m:w-full max-xs:mb-32">
        <a href="/" aria-label="Intermundial — inicio" class="inline-block w-[173px]">
          <span class="text-22 font-weight-medium text-white tracking-0-3 leading-28">
            Intermundial
          </span>
        </a>
      </div>

      <!-- Columnas -->
      <div class="w-auto flex gap-48 max-s:flex-wrap max-s:gap-0">
        {footer.columns.map((col: FooterColumn, idx: number) => (
          <div class="w-[171px] cursor-default max-s:w-full max-s:mb-12 max-xs:mb-12 last:max-s:mb-0">
            <ul>
              <li class="max-s:block max-s:w-full">

                <!-- Título de columna (acordeón en mobile) -->
                <details class="group/col max-s:border-b max-s:border-stroke-high">
                  <summary
                    class="font-helvetica-now-medium font-weight-medium text-16 leading-22 text-white
                           flex justify-between items-center cursor-pointer list-none
                           py-0 max-s:py-14"
                    aria-expanded="false"
                  >
                    <span class="inline-flex h-24 items-center">{col.title}</span>
                    <!-- Flecha solo en mobile -->
                    <svg
                      class="w-[18px] h-[18px] hidden max-s:inline-block transition-transform duration-150 group-open/col:rotate-180"
                      fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>

                  <!-- Submenu items -->
                  {col.items.length > 0 && (
                    <ul class="max-s:pb-12">
                      {col.items.map((sub: FooterSubItem, subIdx: number) => (
                        <li class:list={[
                          'block mb-12 font-helvetica-now-regular font-weight-regular text-14 leading-20 text-white',
                          subIdx === 0 ? 'mt-24 max-s:mt-12' : '',
                        ]}>
                          {sub.url ? (
                            <a
                              href={sub.url}
                              class="hover:underline hover:decoration-white text-white no-underline transition-all duration-150"
                            >
                              <span class="text-white">{sub.nombre}</span>
                            </a>
                          ) : (
                            <span class="text-white opacity-75">{sub.nombre}</span>
                          )}
                        </li>
                      ))}
                    </ul>
                  )}
                </details>

              </li>
            </ul>
          </div>
        ))}
      </div>

    </div>
  </nav>

  <!-- ── 3. App stores + métodos de pago ───────────────────────────── -->
  <div class="px-32 pb-40 pt-0 bg-content-high flex justify-center max-xs:px-24">
    <div class="w-full max-w-[1600px]">
      <div class="grid grid-cols-12 gap-16 items-center">

        <!-- App stores (izquierda) -->
        <div class="col-span-5 max-s:col-span-12 max-xs:col-span-12">
          <div class="flex justify-start max-xs:justify-center gap-16">
            <a
              href="https://apps.apple.com/es/app/intermundial-seguros-de-viaje/id493735699"
              target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-8 h-[40px] px-16 py-8 rounded-8 border border-white text-white text-12
                     hover:bg-white hover:text-content-high transition-colors"
              aria-label="Descargar en App Store"
            >
              <!-- Apple icon -->
              <svg class="w-[16px] h-[16px] flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <span class="font-weight-medium">App Store</span>
            </a>
            <a
              href="https://play.google.com/store/apps/details?id=com.intermundial.android&hl=es"
              target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-8 h-[40px] px-16 py-8 rounded-8 border border-white text-white text-12
                     hover:bg-white hover:text-content-high transition-colors"
              aria-label="Disponible en Google Play"
            >
              <!-- Play icon -->
              <svg class="w-[16px] h-[16px] flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 20.5v-17c0-.83.93-1.3 1.6-.8l14 8.5c.6.36.6 1.24 0 1.6l-14 8.5c-.67.5-1.6.03-1.6-.8z"/>
              </svg>
              <span class="font-weight-medium">Google Play</span>
            </a>
          </div>
        </div>

        <!-- Métodos de pago (derecha) -->
        <div class="col-span-7 max-s:col-span-12 max-xs:col-span-12
                    flex items-center flex-wrap gap-8 justify-end max-s:justify-start max-xs:justify-center">
          {paymentMethods.map((method) => (
            <span
              class="inline-flex items-center justify-center h-[40px] px-12 rounded-4
                     bg-white bg-opacity-10 border border-white border-opacity-20 text-white text-12 font-weight-medium"
              title={method.alt}
            >
              {method.alt}
            </span>
          ))}
        </div>

      </div>
    </div>
  </div>

  <!-- ── 4. Social + Atlantigo + País ─────────────────────────────── -->
  <div class="px-32 pb-24 pt-0 bg-content-high flex justify-center max-xs:px-24 max-xs:pb-16">
    <div class="w-full max-w-[1600px]">
      <div class="grid grid-cols-12 gap-16 items-center">

        <!-- Redes sociales -->
        <div class="col-span-6 max-xs:col-span-12">
          <nav aria-label="Redes sociales" class="flex justify-start items-center max-xs:justify-center max-xs:mb-24">
            <ul class="list-none flex items-center gap-0 m-0 p-0">
              {socialLinks.map((social) => (
                <li>
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={social.label}
                    class="w-24 h-24 inline-flex items-center justify-center mr-24 text-white opacity-75 hover:opacity-100 transition-opacity"
                  >
                    <span class="w-24 h-24" set:html={social.icon} />
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- Atlantigo + selector de país -->
        <div class="col-span-6 max-s:col-span-12 max-xs:col-span-12
                    flex justify-end items-center gap-16 flex-wrap max-xs:gap-24 max-xs:justify-center max-xs:flex-col">

          <!-- Logo Atlantigo + claim -->
          <div class="flex justify-end gap-16 whitespace-nowrap max-xs:justify-center items-center">
            <span class="text-12 leading-18 text-white opacity-75 font-helvetica-now-regular">
              Una campaña de
            </span>
            <a href="https://www.atlantigogroup.com/" target="_blank" rel="noopener noreferrer"
               class="text-white font-weight-medium text-14 hover:underline">
              Atlantigo
            </a>
          </div>

          <!-- Selector de país -->
          <div class="relative w-[240px] bg-transparent text-white border border-white rounded-8 max-xs:w-full">
            <select
              id="select-language"
              class="w-full bg-transparent text-white outline-none cursor-pointer px-16 py-12 pr-40 appearance-none
                     font-helvetica-now-regular font-weight-regular text-14 leading-20"
              onchange="window.location.href = this.value"
            >
              {countries.map((c) => (
                <option class="text-content-high" value={c.url} selected={c.selected || undefined}>
                  {c.label}
                </option>
              ))}
            </select>
            <div class="absolute right-16 top-1/2 -translate-y-1/2 pointer-events-none">
              <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ── 5. Legal nav ──────────────────────────────────────────────── -->
  <nav
    aria-label="Información legal"
    class="py-40 px-32 text-white bg-content-high text-14 flex justify-center max-xs:py-32 max-xs:px-24"
  >
    <div class="w-full max-w-[1600px] flex flex-col gap-40">
      <div class="grid grid-cols-12 gap-16">

        <!-- Copyright (izquierda) -->
        <div class="col-span-3 max-m:col-span-12 text-left max-xs:text-center">
          {footer.legalLeft.map((item: FooterSubItem) => (
            <p class="text-14 leading-20 text-white opacity-75 font-helvetica-now-regular">
              {item.nombre}
            </p>
          ))}
        </div>

        <!-- Links legales (derecha) -->
        <div class="col-span-9 max-m:col-span-12 text-right max-m:text-start max-xs:text-center">
          <ul class="list-none flex items-center gap-16 flex-wrap justify-end max-m:justify-start max-xs:justify-center max-xs:flex-col m-0 p-0">
            {footer.legalRight.map((item: FooterSubItem) => (
              <li class="inline-block align-top pl-[9px] max-xs:pl-0">
                <p class="text-14 leading-20 text-white m-0">
                  {item.url ? (
                    <a
                      href={item.url}
                      target={item.url.startsWith('http') ? '_blank' : '_parent'}
                      rel={item.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                      class="text-white hover:text-white no-underline hover:underline max-s:hover:no-underline transition-all duration-150"
                    >
                      {item.nombre}
                    </a>
                  ) : (
                    <span class="opacity-75">{item.nombre}</span>
                  )}
                </p>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </nav>

</footer>
