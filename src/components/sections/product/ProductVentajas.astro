---
/**
 * ProductVentajas — Grid de ventajas de contratar (miniatura_3).
 *
 * Ref: content_v3/block_v3/miniatura_3/tres_elementos.html.twig
 *
 * Diseño:
 *   Fondo blanco, 3 cards en fila
 *   Cada card: imagen + título + descripción
 *   Mobile: carrusel / columna
 */
import type { Miniatura3Item } from '../../../lib/types';

const BASE_URL = import.meta.env.CMS_BASE_URL as string;

interface Props {
  titulo?:  string;
  items:    Miniatura3Item[];
}

const { titulo = 'Ventajas de contratar en Intermundial', items } = Astro.props;
---

{items.length > 0 && (
  <section class="w-full px-32 max-m:px-24 max-xs:px-16 mb-[96px] max-s:mb-[64px]">

    <!-- Título -->
    {titulo && (
      <h2 class="
        text-center font-helvetica-now-medium font-weight-medium text-content-high
        text-[2rem] max-s:text-[1.75rem] leading-[1.15]
        mb-48 max-s:mb-32
      ">
        {titulo}
      </h2>
    )}

    <!-- Grid de 3 cards -->
    <div class="
      grid grid-cols-3 gap-[32px]
      max-m:grid-cols-2 max-m:gap-[24px]
      max-xs:grid-cols-1 max-xs:gap-[16px]
    ">
      {items.map((item) => {
        const imgUri = item.imagen?.uri ? `${BASE_URL}${item.imagen.uri}` : null;
        return (
          <div class="
            flex flex-col items-start gap-16
            bg-surface-contrast rounded-16 p-32 max-s:p-24
            shadow-stroke-low
          ">
            {imgUri && (
              <img
                src={imgUri}
                alt={item.imagen?.alt || ''}
                width="64"
                height="64"
                class="w-[64px] h-[64px] object-contain"
                loading="lazy"
              />
            )}
            {item.titulo && (
              <h3 class="text-18 leading-[1.3] font-weight-medium text-content-high">
                {item.titulo}
              </h3>
            )}
            {item.descripcion && (
              <p class="text-14 leading-22 text-content-medium font-helvetica-now-regular">
                {item.descripcion}
              </p>
            )}
          </div>
        );
      })}
    </div>

  </section>
)}
